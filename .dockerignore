# Ignore node_modules
**/node_modules
**/dist
**/build
**/.next

# Ignore python artifacts
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
**/.Python
**/pip-log.txt
**/pip-delete-this-directory
**/.venv
**/env/
**/venv/
**/ENV/
**/env.bak/
**/venv.bak/

# Ignore IDE settings
**/.idea
**/.vscode
**/*.swp
**/*.swo

# Ignore logs and data
**/logs/*
**/data/*
!**/data/garment_database.json
!**/data/test_figure.jpg

# Ignore system files
**/.DS_Store
**/Thumbs.db

# Ignore documentation
**/docs
