# Python ML Service Configuration

# Service Settings
PORT=8000
HOST=0.0.0.0
DEBUG=true

# Database Connection (for future use)
DATABASE_URL=postgresql://postgres:secret@localhost:5432/chic_india

# Redis Connection (for future use)
REDIS_URL=redis://localhost:6379

# ML Model Configuration
MODEL_PATH=models/
USE_GPU=true
MIN_CONFIDENCE=0.6

# Camera Settings
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
FPS_LIMIT=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/ml_service.log
